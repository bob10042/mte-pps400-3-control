<UserControl x:Class="MtePpsControl.Views.ParameterSetterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             DataContext="{Binding Setter, RelativeSource={RelativeSource AncestorType=Window}}">
    <DockPanel Margin="20" LastChildFill="True">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Parameter Setter" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource Accent}"/>
            <TextBlock Text="Pick a category and parameter, fill in the values, hit Apply. Drives every command in the spec."
                       Foreground="{StaticResource TextDim}" FontSize="12"/>
        </StackPanel>

        <!-- Action row docked bottom (always visible) -->
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrush1}" BorderThickness="1" CornerRadius="6" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Tip: " Foreground="{StaticResource TextDim}" FontStyle="Italic"/>
                    <TextBlock Foreground="{StaticResource TextDim}" FontStyle="Italic"
                               Text="setpoints queue until you Apply 'SET (apply queued setpoints)' from the Actions category."/>
                </StackPanel>
                <Button Grid.Column="1" Content="Apply parameter" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplyCommand}" MinWidth="160" FontSize="14"/>
            </Grid>
        </Border>

        <!-- Middle: cascade form + log -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*" MinWidth="380"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: cascade form -->
            <Border Grid.Column="0" Margin="0,0,8,0" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush1}" BorderThickness="1" CornerRadius="6" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Category -->
                        <TextBlock Text="Category" Foreground="{StaticResource TextDim}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                                  Margin="0,0,0,12" FontSize="13"/>

                        <!-- Parameter -->
                        <TextBlock Text="Parameter" Foreground="{StaticResource TextDim}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Parameters}" SelectedItem="{Binding SelectedParameter}"
                                  Margin="0,0,0,12" FontSize="13"/>

                        <!-- Phase (only when applicable) -->
                        <StackPanel Visibility="{Binding NeedsPhase, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Phase" Foreground="{StaticResource TextDim}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <RadioButton Content="L1" Margin="0,0,12,0" IsChecked="{Binding SelectedPhase, ConverterParameter=1, Converter={StaticResource IntEqualsCheck}}"
                                             GroupName="psPhase" Foreground="{StaticResource L1}" FontWeight="Bold"/>
                                <RadioButton Content="L2" Margin="0,0,12,0" IsChecked="{Binding SelectedPhase, ConverterParameter=2, Converter={StaticResource IntEqualsCheck}}"
                                             GroupName="psPhase" Foreground="{StaticResource L2}" FontWeight="Bold"/>
                                <RadioButton Content="L3" Margin="0,0,12,0" IsChecked="{Binding SelectedPhase, ConverterParameter=3, Converter={StaticResource IntEqualsCheck}}"
                                             GroupName="psPhase" Foreground="{StaticResource L3}" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Extra inputs (dynamic per parameter) -->
                        <ItemsControl ItemsSource="{Binding ExtraInputs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                                   Foreground="{StaticResource Text}" FontSize="13"/>
                                        <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" FontSize="13"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Unit}" VerticalAlignment="Center"
                                                   Margin="6,0,0,0" Foreground="{StaticResource TextDim}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Notes -->
                        <Border Background="{StaticResource AccentSoft}" CornerRadius="3" Padding="8,6"
                                Margin="0,4,0,0"
                                Visibility="{Binding ParameterNotes, Converter={StaticResource StrToVis}}">
                            <TextBlock Text="{Binding ParameterNotes}" TextWrapping="Wrap" FontSize="12"
                                       Foreground="{StaticResource AccentDark}"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- RIGHT: command log -->
            <Border Grid.Column="1" Margin="8,0,0,0" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush1}" BorderThickness="1" CornerRadius="6" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="12,10,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Recent commands" FontWeight="SemiBold"/>
                        <Button Grid.Column="1" Content="Clear" Style="{StaticResource PanelButton}" MinWidth="60" Padding="8,3"
                                Command="{Binding ClearLogCommand}"/>
                    </Grid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Log}" Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" Padding="6">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="3" Padding="4,1" Margin="0,2,8,2"
                                            VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush>
                                                <SolidColorBrush.Color>
                                                    <Binding Path="Status" Converter="{StaticResource StatusToColor}"/>
                                                </SolidColorBrush.Color>
                                            </SolidColorBrush>
                                        </Border.Background>
                                        <TextBlock Text="{Binding Status}" Foreground="White" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayLine}" FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
