<Window x:Class="MtePpsControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MtePpsControl.ViewModels"
        xmlns:views="clr-namespace:MtePpsControl.Views"
        Title="MTE PPS 400.3 Control" Height="940" Width="1240"
        MinHeight="800" MinWidth="1100"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- Top tab bar — bright blue header, the "blue pane" -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" BorderBrush="{StaticResource AccentDark}"
                BorderThickness="0,0,0,2">
            <StackPanel Orientation="Horizontal" Margin="16,0">
                <StackPanel VerticalAlignment="Center" Margin="0,0,30,0">
                    <TextBlock Text="MTE  PCS 400.3" FontWeight="Bold" FontSize="14" Foreground="White"/>
                    <TextBlock Text="{Binding HeaderModelLine}" FontSize="10" Foreground="#CCFFFFFF" FontFamily="Consolas"/>
                </StackPanel>
                <RadioButton Content="Reference" Style="{StaticResource TopTab}" GroupName="topTabs"
                             Click="TopTabReference_Click"/>
                <RadioButton Content="PPS400.3"  Style="{StaticResource TopTab}" GroupName="topTabs" IsChecked="True"
                             Click="TopTabPps_Click"/>
                <RadioButton Content="Sequence"  Style="{StaticResource TopTab}" GroupName="topTabs"
                             Click="TopTabSequence_Click"/>
                <RadioButton Content="Database"  Style="{StaticResource TopTab}" GroupName="topTabs"
                             Click="TopTabDatabase_Click"/>
            </StackPanel>
        </Border>

        <!-- Body: icon strip + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SideBarWidth}"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush1}" BorderThickness="0,0,1,0"
                    Visibility="{Binding SideBarCollapsed, Converter={StaticResource BoolNot}, ConverterParameter=invert}">
                <StackPanel Orientation="Vertical" Margin="0,8">
                    <RadioButton Style="{StaticResource IconStripButton}" GroupName="iconStrip" IsChecked="True"
                                 ToolTip="Unified parameter setter — pick category + parameter, set anything"
                                 Click="Icon_Setter_Click">
                        <StackPanel>
                            <TextBlock Text="⚙" FontSize="22" HorizontalAlignment="Center" Foreground="{StaticResource Accent}"/>
                            <TextBlock Text="Setter" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource IconStripButton}" GroupName="iconStrip"
                                 IsEnabled="False" ToolTip="kWh meter test (needs PCS comms)">
                        <StackPanel>
                            <TextBlock Text="kWh" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Text="meter" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextDim}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource IconStripButton}" GroupName="iconStrip"
                                 IsEnabled="False" ToolTip="Analog meter test (needs PCS comms)">
                        <StackPanel>
                            <TextBlock Text="A/V" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="meter" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextDim}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource IconStripButton}" GroupName="iconStrip"
                                 ToolTip="Harmonics editor (OWI/OWU)" Click="Icon_Harmonics_Click">
                        <StackPanel>
                            <TextBlock Text="〰" FontSize="20" HorizontalAlignment="Center" Foreground="{StaticResource Accent}"/>
                            <TextBlock Text="Harm." FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource IconStripButton}" GroupName="iconStrip"
                                 IsEnabled="False" ToolTip="Wattmeter test (needs PCS comms)">
                        <StackPanel>
                            <TextBlock Text="W" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="watt" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextDim}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource IconStripButton}" GroupName="iconStrip"
                                 IsEnabled="False" ToolTip="Current transformer test (needs PCS comms)">
                        <StackPanel>
                            <TextBlock Text="][" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="CT" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextDim}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource IconStripButton}" GroupName="iconStrip"
                                 ToolTip="Run a multi-step sequence (capture-from-source then walk steps)" Click="Icon_Sequence_Click">
                        <StackPanel>
                            <TextBlock Text="→" FontSize="22" HorizontalAlignment="Center" Foreground="{StaticResource Accent}"/>
                            <TextBlock Text="Seq." FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource IconStripButton}" GroupName="iconStrip"
                                 ToolTip="Quick-fill source control (3-phase setpoint matrix)" Click="Icon_Source_Click">
                        <StackPanel>
                            <TextBlock Text="∿" FontSize="22" HorizontalAlignment="Center" Foreground="{StaticResource Accent}"/>
                            <TextBlock Text="Source" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource IconStripButton}" GroupName="iconStrip"
                                 ToolTip="Ripple control telegram editor" Click="Icon_Ripple_Click">
                        <StackPanel>
                            <TextBlock Text="⫶⫶" FontSize="16" HorizontalAlignment="Center" Foreground="{StaticResource Accent}"/>
                            <TextBlock Text="Ripple" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource IconStripButton}" GroupName="iconStrip"
                                 ToolTip="Saved presets database" Click="Icon_Database_Click">
                        <StackPanel>
                            <TextBlock Text="🗄" FontSize="20" HorizontalAlignment="Center" Foreground="{StaticResource Accent}"/>
                            <TextBlock Text="DB" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- Sidebar collapse/expand handle -->
            <Button Grid.Column="1" Width="20" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush1}" BorderThickness="0,0,1,0"
                    Cursor="Hand" Command="{Binding ToggleSideBarCommand}"
                    ToolTip="Show / hide the side panel"
                    Padding="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <TextBlock Text="{Binding SideBarToggleGlyph}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="11" Foreground="{StaticResource TextDim}"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Content area: switches based on SelectedView -->
            <ContentControl Grid.Column="2">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedView}" Value="setter">
                                <Setter Property="Content">
                                    <Setter.Value><views:ParameterSetterView/></Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedView}" Value="source">
                                <Setter Property="Content">
                                    <Setter.Value><views:SourceControlView/></Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedView}" Value="harmonics">
                                <Setter Property="Content">
                                    <Setter.Value><views:HarmonicsView/></Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedView}" Value="ripple">
                                <Setter Property="Content">
                                    <Setter.Value><views:RippleView/></Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedView}" Value="sequence">
                                <Setter Property="Content">
                                    <Setter.Value><views:SequenceView/></Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedView}" Value="database">
                                <Setter Property="Content">
                                    <Setter.Value><views:DatabaseView/></Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>

        <!-- Bottom status footer -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrush1}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatusChip}" BorderBrush="{StaticResource L1}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Style="{StaticResource StatusDot}">
                            <Ellipse.Fill><SolidColorBrush Color="{Binding Phases[0].StatusUColor, FallbackValue=#888888}"/></Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="L1" Foreground="{StaticResource L1}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <TextBlock FontFamily="Consolas">
                            <Run Text="{Binding Phases[0].VoltageMeasured, StringFormat=0.0 V}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding Phases[0].CurrentMeasured, StringFormat=0.000 A}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatusChip}" BorderBrush="{StaticResource L2}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Style="{StaticResource StatusDot}">
                            <Ellipse.Fill><SolidColorBrush Color="{Binding Phases[1].StatusUColor, FallbackValue=#888888}"/></Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="L2" Foreground="{StaticResource L2}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <TextBlock FontFamily="Consolas">
                            <Run Text="{Binding Phases[1].VoltageMeasured, StringFormat=0.0 V}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding Phases[1].CurrentMeasured, StringFormat=0.000 A}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatusChip}" BorderBrush="{StaticResource L3}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Style="{StaticResource StatusDot}">
                            <Ellipse.Fill><SolidColorBrush Color="{Binding Phases[2].StatusUColor, FallbackValue=#888888}"/></Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="L3" Foreground="{StaticResource L3}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <TextBlock FontFamily="Consolas">
                            <Run Text="{Binding Phases[2].VoltageMeasured, StringFormat=0.0 V}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding Phases[2].CurrentMeasured, StringFormat=0.000 A}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource StatusChip}" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Style="{StaticResource StatusDot}">
                            <Ellipse.Fill><SolidColorBrush Color="{Binding ConnectionStateColor, FallbackValue=#888888}"/></Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionLabel}" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
